#!/usr/bin/env bash
# cogcog — stdin → LLM → stdout
# Pipe your context in, get a response out.
#
# Usage:
#   echo "explain this" | cogcog
#   cat src/main.ts | cogcog
#   :%!cogcog          (from vim — send whole buffer)
#   :'<,'>!cogcog      (from vim — send selection)
#
# Env:
#   COGCOG_CMD         delegate to another CLI (e.g. "claude -p")
#   COGCOG_API_URL     API endpoint (default: OpenAI-compatible)
#   COGCOG_API_KEY     API key (or OPENAI_API_KEY)
#   COGCOG_MODEL       model name
#   COGCOG_FAST_MODEL  model for --raw fast path
#   COGCOG_MAX_TOKENS  max tokens       (default: 8192)
#   COGCOG_SYSTEM      system prompt    (optional)

set -euo pipefail

_RAW=0
if [[ "${1:-}" == "--raw" ]]; then
  _RAW=1
  shift
elif [[ -n "${COGCOG_CMD:-}" ]]; then
  exec $COGCOG_CMD "$@"
fi

MAX_TOKENS="${COGCOG_MAX_TOKENS:-8192}"
SYSTEM="${COGCOG_SYSTEM:-}"

if [[ $_RAW -eq 1 && -n "${COGCOG_FAST_MODEL:-}" ]]; then
  MODEL="${COGCOG_FAST_MODEL}"
  API_URL="${COGCOG_FAST_API_URL:-${COGCOG_API_URL:-http://localhost:8091/v1/chat/completions}}"
else
  MODEL="${COGCOG_MODEL:-gemma4:26b}"
  API_URL="${COGCOG_API_URL:-http://localhost:8091/v1/chat/completions}"
fi

API_KEY="${COGCOG_API_KEY:-${OPENAI_API_KEY:-dummy}}"

# read stdin
tmp=$(mktemp)
trap 'rm -f "$tmp"' EXIT
cat > "$tmp"

if [[ ! -s "$tmp" ]]; then
  echo "cogcog: empty input" >&2
  exit 1
fi

input=$(<"$tmp")

# build request
if [[ -n "$SYSTEM" ]]; then
  body=$(jq -n \
    --arg model "$MODEL" \
    --argjson max_tokens "$MAX_TOKENS" \
    --arg system "$SYSTEM" \
    --arg content "$input" \
    '{model: $model, max_tokens: $max_tokens, stream: true,
      messages: [{role: "system", content: $system}, {role: "user", content: $content}]}')
else
  body=$(jq -n \
    --arg model "$MODEL" \
    --argjson max_tokens "$MAX_TOKENS" \
    --arg content "$input" \
    '{model: $model, max_tokens: $max_tokens, stream: true,
      messages: [{role: "user", content: $content}]}')
fi

# stream response
curl -sS -N "$API_URL" \
  -H "Authorization: Bearer $API_KEY" \
  -H "content-type: application/json" \
  -d "$body" 2>/dev/null \
| sed -n -u 's/^data: //p' \
| grep -v --line-buffered '^\[DONE\]$' \
| jq -j --unbuffered -r '.choices[0].delta.content // empty' 2>/dev/null \
| {
  output=""
  while IFS= read -r -d '' -n 1 char || [[ -n "$char" ]]; do
    printf '%s' "$char"
    output+="$char"
  done
  [[ -n "$output" ]] && echo
  if [[ -z "$output" ]]; then
    echo "cogcog: empty response" >&2
    exit 1
  fi
}
